{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "NSXTConfiguration",
  "type": "object",
  "properties": {
    "logical_switches": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "properties": {
          "name":             { "type": "string" },
          "transport_zone":   { "type": "string" },
          "vni":              { "type": "integer", "minimum": 5000, "maximum": 16777215 },
          "segment_id":       { "type": "integer", "minimum": 5000, "maximum": 16777215 },
          "admin_state":      { "type": "string", "enum": ["UP", "DOWN"] },
          "replication_mode": { "type": "string", "enum": ["MTEP", "HEAD_REPLICATION", "HIERARCHICAL_TWO_TIER"] }
        },
        "required": ["name", "transport_zone", "vni", "admin_state"]
      }
    },
    "logical_routers": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name":          { "type": "string" },
          "type":          { "type": "string", "enum": ["TIER0", "TIER1"] },
          "ha_mode":       { "type": "string", "enum": ["ACTIVE_STANDBY", "ACTIVE_ACTIVE"] },
          "failover_mode": { "type": "string", "enum": ["PREEMPTIVE", "NON_PREEMPTIVE"] },
          "linked_tier0":  { "type": "string" },
          "interfaces": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "name":           { "type": "string" },
                "ip":             { "type": "string", "pattern": "^\\d{1,3}(\\.\\d{1,3}){3}/\\d{1,2}$" },
                "logical_switch": { "type": "string" },
                "state":          { "type": "string", "enum": ["UP", "DOWN"] }
              },
              "required": ["name", "ip", "logical_switch", "state"]
            }
          }
        },
        "required": ["name", "type", "ha_mode"]
      }
    },
    "firewall_rules": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name":        { "type": "string" },
          "type":        { "type": "string", "enum": ["Distributed", "Gateway"] },
          "source":      { "type": "string" },
          "destination": { "type": "string" },
          "service":     { "type": "string" },
          "action":      { "type": "string", "enum": ["ALLOW", "DROP", "REJECT"] },
          "direction":   { "type": "string", "enum": ["IN", "OUT", "IN_OUT"] },
          "applied_to":  { "type": "string" }
        },
        "required": ["name", "source", "destination", "action", "direction"]
      }
    }
  },
  "required": ["logical_switches", "logical_routers", "firewall_rules"]
}
