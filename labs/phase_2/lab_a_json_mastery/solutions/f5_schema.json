{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "F5LTMConfiguration",
  "type": "object",
  "properties": {
    "virtual_servers": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name":                    { "type": "string" },
          "destination":             { "type": "string", "pattern": "^\\d{1,3}(\\.\\d{1,3}){3}:\\d+$" },
          "ip_protocol":             { "type": "string", "enum": ["tcp", "udp"] },
          "pool":                    { "type": "string" },
          "source_address_translation": {
            "type": "object",
            "properties": {
              "type": { "type": "string", "enum": ["automap", "snat", "none"] }
            },
            "required": ["type"]
          },
          "translate_address":       { "type": "string", "enum": ["enabled", "disabled"] },
          "translate_port":          { "type": "string", "enum": ["enabled", "disabled"] }
        },
        "required": ["name", "destination", "ip_protocol", "pool"]
      }
    },
    "pools": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name":               { "type": "string" },
          "monitor":            { "type": "string" },
          "min_active_members": { "type": "integer", "minimum": 1 },
          "members": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "properties": {
                "address": { "type": "string" },
                "port":    { "type": "integer", "minimum": 1, "maximum": 65535 },
                "session": { "type": "string", "enum": ["monitor-enabled", "user-disabled"] },
                "state":   { "type": "string", "enum": ["up", "down", "unchecked"] }
              },
              "required": ["address", "port"]
            }
          }
        },
        "required": ["name", "members", "min_active_members"]
      }
    },
    "monitors": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name":         { "type": "string" },
          "type":         { "type": "string", "enum": ["http", "https", "tcp", "icmp"] },
          "interval":     { "type": "integer", "minimum": 1, "maximum": 86400 },
          "timeout":      { "type": "integer", "minimum": 1, "maximum": 86400 },
          "send":         { "type": "string" },
          "recv":         { "type": "string" }
        },
        "required": ["name", "type", "interval", "timeout"]
      }
    }
  },
  "required": ["virtual_servers", "pools"]
}
