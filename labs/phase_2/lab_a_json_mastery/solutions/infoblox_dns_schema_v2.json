{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "zone": {
      "type": "string"
    },
    "view": {
      "type": "string"
    },
    "a_records": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "ip": {
            "type": "string"
          },
          "comment": {
            "type": "string"
          }
        },
        "required": [
          "name",
          "ip"
        ]
      }
    },
    "cname_records": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "target": {
            "type": "string"
          }
        },
        "required": [
          "name",
          "target"
        ]
      }
    },
    "txt_records": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "text": {
            "type": "string"
          }
        },
        "required": [
          "text"
        ]
      }
    },
    "srv_records": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "target": {
            "type": "string"
          },
          "port": {
            "type": "integer",
            "minimum": 1,
            "maximum": 65535
          },
          "priority": {
            "type": "integer"
          },
          "weight": {
            "type": "integer"
          }
        },
        "required": [
          "name",
          "target",
          "port"
        ]
      }
    }
  },
  "required": [
    "zone"
  ]
}