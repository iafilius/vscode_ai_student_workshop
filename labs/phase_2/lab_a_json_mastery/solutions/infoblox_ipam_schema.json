{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "InfobloxIPAMConfiguration",
  "type": "object",
  "properties": {
    "networks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "properties": {
          "cidr":        { "type": "string", "pattern": "^\\d{1,3}(\\.\\d{1,3}){3}/\\d{1,2}$" },
          "comment":     { "type": "string" },
          "vlan":        { "type": "string" },
          "site":        { "type": "string" },
          "status":      { "type": "string", "enum": ["Active", "Inactive", "Reserved"] },
          "utilization_percent": {
            "type": "integer",
            "minimum": 0,
            "maximum": 100
          },
          "host_records": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "fqdn":   { "type": "string" },
                "ip":     { "type": "string" },
                "mac":    { "type": "string", "pattern": "^([0-9a-f]{2}:){5}[0-9a-f]{2}$" },
                "status": { "type": "string", "enum": ["Active", "Reserved", "Inactive"] },
                "dhcp":   { "type": "string", "enum": ["Enabled", "Disabled"] }
              },
              "required": ["fqdn", "ip", "status"]
            }
          }
        },
        "required": ["cidr", "site", "status"]
      }
    }
  },
  "required": ["networks"]
}
