{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "networks": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "network": {
            "type": "string"
          },
          "comment": {
            "type": "string"
          },
          "extensible_attributes": {
            "type": "object",
            "additionalProperties": {
              "type": "string"
            }
          },
          "dhcp_range": {
            "type": "object",
            "properties": {
              "start": {
                "type": "string"
              },
              "end": {
                "type": "string"
              }
            },
            "required": [
              "start",
              "end"
            ]
          },
          "fixed_addresses": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "ip": {
                  "type": "string"
                },
                "mac": {
                  "type": "string"
                },
                "comment": {
                  "type": "string"
                }
              },
              "required": [
                "ip",
                "mac"
              ]
            }
          }
        },
        "required": [
          "network"
        ]
      }
    }
  }
}